# ─────────────────────────────────────────────
# Configuración de monitoreo — AcuiCal Status
# Basado en Upptime (https://upptime.js.org)
# ─────────────────────────────────────────────

sites:
  - name: "App AcuiCal"
    url: "https://app.acuical.com"
  - name: "Landing"
    url: "https://acuical.com"
  - name: "Master Panel"
    url: "https://master.acuical.com"
  - name: "API Health"
    url: "https://smvjffbeshxcfltjoolm.supabase.co/functions/v1/health"
  - name: "Acuarismo"
    url: "https://acuarismo.acuical.com"
  - name: "AcuiGen NFC"
    url: "https://acuigen.acuical.com"

assignees:
  - acuicolasvientoenpopa

status-website:
  baseUrl: /status
  logoUrl: https://app.acuical.com/favicon.svg
  name: "AcuiCal Status"
  introTitle: "**Estado de los servicios AcuiCal**"
  introMessage: |
    Monitoreo automatizado de todos los servicios del ecosistema AcuiCal.
    Las verificaciones se realizan cada 5 minutos desde GitHub Actions.
  navbar:
    - title: "Estado"
      href: /
    - title: "AcuiCal"
      href: https://acuical.com
    - title: "App"
      href: https://app.acuical.com
    - title: "GitHub"
      href: https://github.com/acuicolasvientoenpopa

skipDeleteIssues: true

user-agent: "acucal-status"

workflowSchedule:
  graphs: "0 0 * * *"
  responseTime: "0 23 * * *"
  staticSite: "0 1 * * *"
  summary: "0 0 * * *"
  updateTemplate: "0 0 * * *"
  updates: "0 3 * * *"
  uptime: "*/5 * * * *"

i18n:
  active: "Operativo"
  degraded: "Degradado"
  down: "Caído"
  loading: "Verificando..."
  notFoundMessage: "No encontrado"
  error: "Error"
